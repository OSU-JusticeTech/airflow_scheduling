# Database config
DB_USER=your_postgres_user
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=justicetech_db

# Docker/Compose host path to the cases data directory
# Example: ./cases or /absolute/path/to/cases
CASES_HOST_DIR=./cases

# Airflow admin bootstrap (used by docker-compose airflow-init)
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=change_me
AIRFLOW_ADMIN_FIRSTNAME=Admin
AIRFLOW_ADMIN_LASTNAME=User
AIRFLOW_ADMIN_EMAIL=admin@example.com

# CVG OCR DAG config
CVG_CASE_DIRS_ROOT=~/Desktop/justicetech/k3s.dranspo.se:8000/data
CVG_OCR_DIR=./ocr
CVG_RAW_TEXT_DIR=./ocr/raw_text
CVG_JSON_OUTPUT_DIR=./ocr/texts
CVG_BATCH_SIZE=3
CVG_OCR_SCHEDULE=@daily
CVG_OCR_CATCHUP=false
CVG_OCR_START_DATE=2026-03-11
CVG_GLINER_TIMEOUT_SECONDS=180
CVG_ADDRESS_TIMEOUT_SECONDS=60
